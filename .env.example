# PretGo — Variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env  (Windows)

# Fuseau horaire
TZ=Europe/Paris

# Port d'écoute (modifiez si le port 5000 est déjà utilisé)
PRETGO_PORT=5000

# Clé secrète Flask (laisser vide = générée automatiquement)
# Recommandé en production : python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Chemins des données (optionnel — valeurs par défaut si non renseigné)
# PRETGO_DATA_PATH=./docker-data/data
# PRETGO_UPLOADS_PATH=./docker-data/uploads/materiel
